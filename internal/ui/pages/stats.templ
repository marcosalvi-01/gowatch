package pages

import (
	"fmt"
	"github.com/marcosalvi-01/gowatch/internal/models"
	"github.com/marcosalvi-01/gowatch/internal/utils"
	"github.com/marcosalvi-01/gowatch/internal/ui/components/calendarheatmap"
	"github.com/marcosalvi-01/gowatch/internal/ui/components/statscollectioncard"
	"github.com/marcosalvi-01/gowatch/internal/ui/templui/avatar"
	"github.com/marcosalvi-01/gowatch/internal/ui/templui/card"
	"github.com/marcosalvi-01/gowatch/internal/ui/templui/chart"
	"github.com/marcosalvi-01/gowatch/internal/ui/templui/icon"
	"github.com/marcosalvi-01/gowatch/internal/ui/templui/selectbox"
	"github.com/marcosalvi-01/gowatch/internal/ui/templui/skeleton"
	"strconv"
	"strings"
	"time"
)

// getGenreColors returns the shared genre color palette
func getGenreColors() []any {
	return []any{
		"rgba(59, 130, 246, 0.8)", // Blue
		"rgba(16, 185, 129, 0.8)", // Green
		"rgba(245, 158, 11, 0.8)", // Yellow
		"rgba(239, 68, 68, 0.8)",  // Red
		"rgba(139, 92, 246, 0.8)", // Purple
		"rgba(236, 72, 153, 0.8)", // Pink (Others)
	}
}

// getGenreBorderColors returns the shared genre border color palette
func getGenreBorderColors() []any {
	return []any{
		"rgba(59, 130, 246, 1)", // Blue
		"rgba(16, 185, 129, 1)", // Green
		"rgba(245, 158, 11, 1)", // Yellow
		"rgba(239, 68, 68, 1)",  // Red
		"rgba(139, 92, 246, 1)", // Purple
		"rgba(236, 72, 153, 1)", // Pink (Others)
	}
}

templ Stats(stats *models.WatchedStats, limit int) {
	@Layout() {
		@templ.Fragment("content") {
			<div class="space-y-7 sm:space-y-8 pb-5">
				@statsHeader(limit)
				@statsAtGlance(stats)
				@statsActivitySection(stats)
				@statsTasteSection(stats)
				@statsRatingsSection(stats)
				@statsPeopleSection(stats, limit)
				@statsRuntimeFinancialSection(stats)
			</div>
		}
	}
}

templ statsSectionHeader(title string, iconFn func(...icon.Props) templ.Component) {
	<h2 class="text-xl font-semibold flex items-center gap-2">
		@iconFn(icon.Props{Class: "size-5 text-primary"})
		{ title }
	</h2>
}

templ statsAtGlance(stats *models.WatchedStats) {
	<div class="space-y-4">
		@statsSectionHeader("At a Glance", icon.Sparkles)
		@card.Card() {
			@card.Content(card.ContentProps{Class: "p-4 sm:p-6"}) {
				<div class="grid grid-cols-2 sm:grid-cols-3 xl:grid-cols-6 gap-4">
					@statsMetricCard("Total Watched", fmt.Sprintf("%d", stats.TotalWatched), icon.Film)
					@statsMetricCard("Rated Watches", fmt.Sprintf("%d", stats.Ratings.Summary.RatedCount), icon.Star)
					@statsMetricCard("Rewatches", fmt.Sprintf("%d", stats.RewatchStats.RewatchCount), icon.RefreshCcw)
					@statsMetricCard("Unique Movies", fmt.Sprintf("%d", stats.RewatchStats.UniqueMovieCount), icon.Clapperboard)
					@statsMetricCard("Longest Streak", fmt.Sprintf("%d days", stats.LongestStreak.LongestDays), icon.Flame)
					@statsMetricCard("Total Hours", fmt.Sprintf("%.1f", stats.TotalHoursWatched), icon.Clock)
				</div>
			}
		}
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
			@card.Card() {
				@card.Content(card.ContentProps{Class: "p-4 sm:p-6"}) {
					<div class="py-4 text-center">
						<div class="text-sm text-muted-foreground mb-1">Current Streak</div>
						<div class="text-3xl font-bold text-primary">{ fmt.Sprintf("%d days", stats.LongestStreak.CurrentDays) }</div>
					</div>
				}
			}
			@card.Card() {
				@card.Content(card.ContentProps{Class: "p-4 sm:p-6"}) {
					<div class="py-4 text-center">
						<div class="text-sm text-muted-foreground mb-1">Most Watched Day</div>
						if stats.MostWatchedDay != nil {
							<div class="text-lg font-semibold">{ stats.MostWatchedDay.Date.Format("2 Jan 2006") }</div>
							<div class="text-sm text-muted-foreground">{ fmt.Sprintf("%d watches", stats.MostWatchedDay.Count) }</div>
						} else {
							<div class="text-lg font-semibold">No data</div>
						}
					</div>
				}
			}
			@card.Card(card.Props{Class: "h-full"}) {
				@card.Content(card.ContentProps{Class: "p-4 sm:p-6 h-full flex items-center"}) {
					<div class="grid grid-cols-3 w-full text-center">
						<div>
							<div class="text-xs text-muted-foreground pb-2">Avg/Day</div>
							<div class="text-lg xl:text-2xl font-semibold">{ fmt.Sprintf("%.1f", stats.AvgPerDay) }</div>
						</div>
						<div>
							<div class="text-xs text-muted-foreground pb-2">Avg/Week</div>
							<div class="text-lg xl:text-2xl font-semibold">{ fmt.Sprintf("%.1f", stats.AvgPerWeek) }</div>
						</div>
						<div>
							<div class="text-xs text-muted-foreground pb-2">Avg/Month</div>
							<div class="text-lg xl:text-2xl font-semibold">{ fmt.Sprintf("%.1f", stats.AvgPerMonth) }</div>
						</div>
					</div>
				}
			}
		</div>
	</div>
}

templ statsActivitySection(stats *models.WatchedStats) {
	<div class="space-y-4">
		@statsSectionHeader("Activity & Consistency", icon.Activity)
		@calendarheatmap.CalendarHeatmapCard(stats.DailyWatchCountsLastYear)
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
			@card.Card(card.Props{Class: "h-full"}) {
				@card.Header() {
					@card.Title() {
						Watches by Year
					}
				}
				@card.Content(card.ContentProps{Class: "pt-4"}) {
					@chart.Chart(chart.Props{
						Variant:     chart.VariantBar,
						Data:        prepareYearlyData(stats.YearlyAllTime),
						Options:     chart.Options{Responsive: true},
						ShowXAxis:   true,
						ShowXLabels: true,
						ShowYAxis:   true,
						ShowYLabels: true,
						Class:       "h-56 sm:h-60",
					})
				}
			}
			@card.Card(card.Props{Class: "h-full"}) {
				@card.Header() {
					@card.Title() {
						Movies per Month
					}
				}
				@card.Content(card.ContentProps{Class: "pt-4"}) {
					@chart.Chart(chart.Props{
						Variant:     chart.VariantBar,
						Data:        prepareMonthlyMoviesData(stats.MonthlyLastYear),
						Options:     chart.Options{Responsive: true},
						ShowXAxis:   true,
						ShowXLabels: true,
						ShowYAxis:   true,
						ShowYLabels: true,
						Class:       "h-56",
					})
				}
			}
			@card.Card(card.Props{Class: "h-full"}) {
				@card.Header() {
					@card.Title() {
						Weekday Distribution
					}
				}
				@card.Content(card.ContentProps{Class: "pt-4"}) {
					@chart.Chart(chart.Props{
						Variant:     chart.VariantBar,
						Data:        prepareWeekdayData(stats.WeekdayDistribution),
						Options:     chart.Options{Responsive: true},
						ShowXAxis:   true,
						ShowXLabels: true,
						ShowYAxis:   true,
						ShowYLabels: true,
						Class:       "h-56",
					})
				}
			}
		</div>
	</div>
}

templ statsTasteSection(stats *models.WatchedStats) {
	<div class="space-y-4">
		@statsSectionHeader("Taste & Discovery", icon.Palette)
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
			@card.Card(card.Props{Class: "h-full"}) {
				@card.Header() {
					@card.Title() {
						Genres
					}
				}
				@card.Content(card.ContentProps{Class: "pt-4"}) {
					@chart.Chart(chart.Props{
						Variant:    chart.VariantPie,
						Data:       prepareGenresData(stats.Genres),
						Options:    chart.Options{Responsive: true, Legend: true},
						ShowLegend: true,
						Class:      "h-56",
					})
				}
			}
			@card.Card(card.Props{Class: "h-full"}) {
				@card.Header() {
					@card.Title() {
						Theater vs Home
					}
				}
				@card.Content(card.ContentProps{Class: "pt-4"}) {
					@chart.Chart(chart.Props{
						Variant:    chart.VariantDoughnut,
						Data:       prepareTheaterData(stats.TheaterVsHome),
						Options:    chart.Options{Responsive: true, Legend: true},
						ShowLegend: true,
						Class:      "h-56",
					})
				}
			}
			@card.Card(card.Props{Class: "h-full"}) {
				@card.Header() {
					@card.Title() {
						Movie Release Years
					}
				}
				@card.Content(card.ContentProps{Class: "pt-4"}) {
					@chart.Chart(chart.Props{
						Variant:     chart.VariantBar,
						Data:        prepareReleaseYearDistributionData(stats.ReleaseYearDistribution),
						Options:     chart.Options{Responsive: true},
						ShowXAxis:   true,
						ShowXLabels: true,
						ShowYAxis:   true,
						ShowYLabels: true,
						Class:       "h-56",
					})
				}
			}
		</div>
		@card.Card() {
			@card.Header() {
				@card.Title() {
					Genres by Month
				}
			}
			@card.Content(card.ContentProps{Class: "pt-4"}) {
				@chart.Chart(chart.Props{
					Variant:     chart.VariantBar,
					Stacked:     true,
					ShowLegend:  true,
					ShowYGrid:   true,
					ShowXLabels: true,
					Data:        prepareGenresByMonthData(stats.MonthlyGenreBreakdown),
					Class:       "h-64 sm:h-72",
				})
			}
		}
	</div>
}

templ statsRatingsSection(stats *models.WatchedStats) {
	<div class="space-y-4">
		@statsSectionHeader("Ratings & Ranking", icon.Star)
		<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4">
			@ratingMetricCard(
				"Avg Rating",
				formatRatingValue(stats.Ratings.Summary.AverageRating, stats.Ratings.Summary.RatedCount),
				fmt.Sprintf("%d rated watches", stats.Ratings.Summary.RatedCount),
				icon.Star,
			)
			@ratingMetricCard(
				"Rated Watches %",
				formatPercentage(stats.Ratings.Summary.Coverage),
				fmt.Sprintf("%d of %d watched entries rated", stats.Ratings.Summary.RatedCount, stats.TotalWatched),
				icon.BadgePercent,
			)
			@ratingMetricCard(
				"You vs TMDB",
				formatRatingDifference(stats.Ratings.VsTMDB.AverageDifference, stats.Ratings.VsTMDB.ComparedMovieCount),
				fmt.Sprintf("%d rated movies compared", stats.Ratings.VsTMDB.ComparedMovieCount),
				icon.CirclePercent,
			)
			@theaterVsHomeMetricCard(stats.Ratings.TheaterVsHome)
		</div>
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
			@card.Card(card.Props{Class: "h-full"}) {
				@card.Header() {
					@card.Title() {
						Rating Distribution
					}
				}
				@card.Content(card.ContentProps{Class: "pt-4"}) {
					@chart.Chart(chart.Props{
						Variant:     chart.VariantBar,
						Data:        prepareRatingDistributionData(stats.Ratings.Distribution),
						Options:     chart.Options{Responsive: true},
						ShowXAxis:   true,
						ShowXLabels: true,
						ShowYAxis:   true,
						ShowYLabels: true,
						Class:       "h-56",
					})
				}
			}
			@card.Card(card.Props{Class: "h-full"}) {
				@card.Header() {
					@card.Title() {
						Average Rating by Month
					}
				}
				@card.Content(card.ContentProps{Class: "pt-4"}) {
					{{ yMin := 0.0 }}
					{{ yMax := 5.0 }}
					@chart.Chart(chart.Props{
						Variant:     chart.VariantBar,
						Data:        prepareMonthlyAverageRatingData(stats.Ratings.MonthlyAverage),
						Options:     chart.Options{Responsive: true},
						ShowXAxis:   true,
						ShowXLabels: true,
						ShowYAxis:   true,
						ShowYLabels: true,
						YMin:        &yMin,
						YMax:        &yMax,
						Class:       "h-56",
					})
				}
			}
			@card.Card(card.Props{Class: "h-full"}) {
				@card.Header() {
					@card.Title() {
						Rating by Release Decade
					}
				}
				@card.Content(card.ContentProps{Class: "pt-4"}) {
					{{ yMin := 0.0 }}
					{{ yMax := 5.0 }}
					@chart.Chart(chart.Props{
						Variant:     chart.VariantBar,
						Data:        prepareReleaseDecadeRatingData(stats.Ratings.ReleaseDecades),
						Options:     chart.Options{Responsive: true},
						ShowXAxis:   true,
						ShowXLabels: true,
						ShowYAxis:   true,
						ShowYLabels: true,
						YMin:        &yMin,
						YMax:        &yMax,
						Class:       "h-56",
					})
				}
			}
		</div>
		<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
			@highestRatedMoviesCard(stats.Ratings.HighestRatedMovies)
			@ratedPeopleCard("Favorite Directors", stats.Ratings.FavoriteDirectors)
			@ratedPeopleCard("Favorite Actors", stats.Ratings.FavoriteActors)
		</div>
		@rewatchRatingDriftCard(stats.Ratings.RewatchDrift)
	</div>
}

templ statsPeopleSection(stats *models.WatchedStats, limit int) {
	<div class="space-y-4">
		@statsSectionHeader("People & Languages", icon.Users)
		<div class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-6">
			@topMoviesCard(stats.MostWatchedMovies)
			@topActorsCard("Most Watched Male Actors", int64(2), stats.MostWatchedActors, limit)
			@topActorsCard("Most Watched Female Actors", int64(1), stats.MostWatchedActors, limit)
			@topCrewCard("Top Directors", stats.TopDirectors)
			@topCrewCard("Top Writers", stats.TopWriters)
			@topCrewCard("Top Composers", stats.TopComposers)
			@topCrewCard("Top Cinematographers", stats.TopCinematographers)
			@topLanguagesCard(stats.TopLanguages)
		</div>
	</div>
}

templ statsRuntimeFinancialSection(stats *models.WatchedStats) {
	<div class="space-y-4">
		@statsSectionHeader("Runtime & Financials", icon.BadgeDollarSign)
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
			@runtimeExtremesCard(stats.LongestMovieWatched, stats.ShortestMovieWatched)
			@card.Card(card.Props{Class: "h-full"}) {
				@card.Header() {
					@card.Title() {
						Budget Distribution
					}
				}
				@card.Content(card.ContentProps{Class: "pt-4"}) {
					@chart.Chart(chart.Props{
						Variant:    chart.VariantDoughnut,
						Data:       prepareBudgetTierDistributionData(stats.BudgetTierDistribution),
						Options:    chart.Options{Responsive: true, Legend: true},
						ShowLegend: true,
						Class:      "h-56",
					})
				}
			}
		</div>
		<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
			@movieFinancialCard("Top ROI Movies", stats.TopReturnOnInvestmentMovies, true)
			@movieFinancialCard("Biggest Budget Movies", stats.BiggestBudgetMovies, false)
		</div>
	</div>
}

templ ratingMetricCard(label, value, detail string, iconFunc func(...icon.Props) templ.Component) {
	@card.Card(card.Props{Class: "h-full"}) {
		@card.Content(card.ContentProps{Class: "p-4 sm:p-6 h-full"}) {
			<div class="flex h-full items-start justify-between gap-4">
				<div class="min-w-0 flex-1">
					<div class="text-sm text-muted-foreground">{ label }</div>
					<div class="mt-3 text-3xl font-bold leading-none">{ value }</div>
					<div class="mt-2 text-sm text-muted-foreground">{ detail }</div>
				</div>
				<div class="rounded-md bg-primary/10 p-2 shrink-0">
					@iconFunc(icon.Props{Class: "size-[18px] text-primary"})
				</div>
			</div>
		}
	}
}

templ theaterVsHomeMetricCard(data []models.TheaterRating) {
	{{ theater := findTheaterRating(data, true) }}
	{{ home := findTheaterRating(data, false) }}
	@card.Card(card.Props{Class: "h-full"}) {
		@card.Content(card.ContentProps{Class: "p-4 sm:p-6 h-full"}) {
			if theater.RatedCount == 0 && home.RatedCount == 0 {
				<div class="flex h-full items-start justify-between gap-4">
					<div class="min-w-0 flex-1">
						<div class="text-sm text-muted-foreground">Theater vs Home</div>
						<div class="mt-3 text-3xl font-bold leading-none">N/A</div>
						<div class="mt-2 text-sm text-muted-foreground">No ratings yet</div>
					</div>
					<div class="rounded-md bg-primary/10 p-2 shrink-0">
						@icon.Film(icon.Props{Class: "size-[18px] text-primary"})
					</div>
				</div>
			} else {
				<div class="flex h-full items-start justify-between gap-4">
					<div class="min-w-0 flex-1">
						<div class="text-sm text-muted-foreground">Theater vs Home</div>
						<div class="mt-4 grid grid-cols-2 gap-4">
							<div>
								<div class="text-xs text-muted-foreground mb-1">Theater</div>
								<div class="text-lg font-semibold">{ formatRatingValue(theater.AverageRating, theater.RatedCount) }</div>
								<div class="mt-1 text-xs text-muted-foreground">{ fmt.Sprintf("%d ratings", theater.RatedCount) }</div>
							</div>
							<div>
								<div class="text-xs text-muted-foreground mb-1">Home</div>
								<div class="text-lg font-semibold">{ formatRatingValue(home.AverageRating, home.RatedCount) }</div>
								<div class="mt-1 text-xs text-muted-foreground">{ fmt.Sprintf("%d ratings", home.RatedCount) }</div>
							</div>
						</div>
					</div>
					<div class="rounded-md bg-primary/10 p-2 shrink-0">
						@icon.Film(icon.Props{Class: "size-[18px] text-primary"})
					</div>
				</div>
			}
		}
	}
}

templ highestRatedMoviesCard(movies []models.RatedMovie) {
	@statscollectioncard.StatsCollectionCard(statscollectioncard.Props{Title: "Highest Rated Movies", Count: len(movies)}) {
		for _, movie := range movies {
			<div
				data-page="movie"
				hx-get={ "/movie/" + strconv.FormatInt(movie.ID, 10) }
				hx-target="#main-content"
				hx-push-url="true"
				hx-swap="scroll:#main-scroll-container:top"
				hx-indicator="#movie-loading"
				class="rounded-lg border border-border/60 bg-muted/15 p-3 cursor-pointer hover:bg-muted/30 transition-colors"
			>
				<div class="flex items-center gap-3">
					@moviePosterThumb(movie.PosterPath, movie.Title)
					<div class="min-w-0 flex-1">
						<div class="font-medium text-sm line-clamp-1">{ movie.Title }</div>
						<div class="mt-1 text-xs text-muted-foreground">{ formatRatingValue(movie.AverageRating, movie.RatedWatchCount) }</div>
						<div class="mt-1 text-xs text-muted-foreground">{ fmt.Sprintf("%d rated watches", movie.RatedWatchCount) }</div>
					</div>
				</div>
			</div>
		}
	}
}

templ ratedPeopleCard(title string, people []models.RatedPerson) {
	@statscollectioncard.StatsCollectionCard(statscollectioncard.Props{Title: title, Count: len(people)}) {
		for _, person := range people {
			{{ personHref := personPagePath(person.ID) }}
			if personHref != "" {
				<div
					data-page="person"
					hx-get={ personHref }
					hx-target="#main-content"
					hx-push-url="true"
					hx-swap="scroll:#main-scroll-container:top"
					hx-indicator="#person-loading"
					class="flex items-center gap-3 rounded-md border border-border/50 bg-muted/15 px-3 py-2 cursor-pointer hover:bg-muted/30 transition-colors"
				>
					@actorRowAvatar(person.Name, person.ProfilePath)
					<div class="flex-1 min-w-0">
						<div class="font-medium text-sm line-clamp-1">{ person.Name }</div>
						<div class="text-xs text-muted-foreground">{ formatRatingValue(person.AverageRating, person.RatedMovieCount) } | { fmt.Sprintf("%d rated movies", person.RatedMovieCount) }</div>
					</div>
				</div>
			} else {
				<div class="flex items-center gap-3 rounded-md border border-border/50 bg-muted/15 px-3 py-2">
					@actorRowAvatar(person.Name, person.ProfilePath)
					<div class="flex-1 min-w-0">
						<div class="font-medium text-sm line-clamp-1">{ person.Name }</div>
						<div class="text-xs text-muted-foreground">{ formatRatingValue(person.AverageRating, person.RatedMovieCount) } | { fmt.Sprintf("%d rated movies", person.RatedMovieCount) }</div>
					</div>
				</div>
			}
		}
	}
}

templ rewatchRatingDriftCard(drifts []models.RewatchRatingDrift) {
	@statscollectioncard.StatsCollectionCard(statscollectioncard.Props{Title: "Rewatch Rating Drift", Count: len(drifts)}) {
		for _, drift := range drifts {
			<div
				data-page="movie"
				hx-get={ "/movie/" + strconv.FormatInt(drift.MovieID, 10) }
				hx-target="#main-content"
				hx-push-url="true"
				hx-swap="scroll:#main-scroll-container:top"
				hx-indicator="#movie-loading"
				class="rounded-lg border border-border/60 bg-muted/15 p-3 cursor-pointer hover:bg-muted/30 transition-colors"
			>
				<div class="flex items-center gap-3">
					@moviePosterThumb(drift.PosterPath, drift.Title)
					<div class="min-w-0 flex-1">
						<div class="font-medium text-sm line-clamp-1">{ drift.Title }</div>
						<div class="mt-1 text-xs text-muted-foreground">
							First { fmt.Sprintf("%.1f/5", drift.FirstRating) }
							| Last { fmt.Sprintf("%.1f/5", drift.LastRating) }
							| Change { formatSignedFloat(drift.RatingChange) }
						</div>
						<div class="mt-1 text-xs text-muted-foreground">
							{ drift.FirstWatchedDate.Format("Jan 2006") }
							| { drift.LastWatchedDate.Format("Jan 2006") }
							| { fmt.Sprintf("%d rated watches", drift.RatedWatchCount) }
						</div>
					</div>
				</div>
			</div>
		}
	}
}


templ topMoviesCard(movies []models.TopMovie) {
	@statscollectioncard.StatsCollectionCard(statscollectioncard.Props{Title: "Most Watched Movies", Count: len(movies)}) {
		for _, movie := range movies {
			<div
				data-page="movie"
				hx-get={ "/movie/" + strconv.FormatInt(movie.ID, 10) }
				hx-target="#main-content"
				hx-push-url="true"
				hx-swap="scroll:#main-scroll-container:top"
				hx-indicator="#movie-loading"
				class="rounded-lg border border-border/60 bg-muted/15 p-3 cursor-pointer hover:bg-muted/30 transition-colors"
			>
				<div class="flex items-center gap-3">
					@moviePosterThumb(movie.PosterPath, movie.Title)
					<div class="min-w-0 flex-1">
						<div class="font-medium text-sm line-clamp-1">{ movie.Title }</div>
						<div class="mt-1 text-xs text-muted-foreground">{ fmt.Sprintf("%d watches", movie.WatchCount) }</div>
					</div>
				</div>
			</div>
		}
	}
}

templ topActorsCard(title string, gender int64, actors []models.TopActor, limit int) {
	{{ filteredActors := filterTopActorsByGender(actors, gender, limit) }}
	@statscollectioncard.StatsCollectionCard(statscollectioncard.Props{Title: title, Count: len(filteredActors)}) {
		for _, actor := range filteredActors {
			{{ personHref := personPagePath(actor.ID) }}
