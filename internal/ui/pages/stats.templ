}

func prepareMonthlyHoursData(data []models.PeriodHours) chart.Data {
	// Create a map of period to hours
	dataMap := make(map[string]float64)
	for _, ph := range data {
		dataMap[ph.Period] = ph.Hours
	}

	// Generate last 12 complete months
	now := time.Now()
	labels := make([]string, 12)
	values := make([]float64, 12)
	for i := 11; i >= 0; i-- {
		month := now.AddDate(0, -i, 0)
		period := month.Format("2006-01")
		label := month.Format("Jan")
		labels[11-i] = label
		values[11-i] = float64(dataMap[period])
	}

	return chart.Data{
		Labels: labels,
		Datasets: []chart.Dataset{{
			Label:           "Hours",
			Data:            values,
			BackgroundColor: []any{"rgba(245, 158, 11, 0.5)"},
			BorderColor:     []any{"rgba(245, 158, 11, 1)"},
			BorderWidth:     1,
		}},
	}
}

func prepareReleaseYearDistributionData(data []models.ReleaseYearCount) chart.Data {
	labels := make([]string, len(data))
	values := make([]float64, len(data))

	for i, item := range data {
		labels[i] = strconv.Itoa(item.Year)
		values[i] = float64(item.Count)
	}

	return chart.Data{
		Labels: labels,
		Datasets: []chart.Dataset{{
			Label:           "Movies",
			Data:            values,
			BackgroundColor: []any{"rgba(34, 197, 94, 0.5)"},
			BorderColor:     []any{"rgba(34, 197, 94, 1)"},
			BorderWidth:     1,
		}},
	}
}

func prepareBudgetTierDistributionData(data []models.BudgetTierCount) chart.Data {
	labels := make([]string, 0, len(data))
	values := make([]float64, 0, len(data))
	colors := []any{
		"rgba(34, 197, 94, 0.8)",  // Indie
		"rgba(59, 130, 246, 0.8)", // Mid
		"rgba(245, 158, 11, 0.8)", // Blockbuster
		"rgba(107, 114, 128, 0.8)",
	}

	for _, item := range data {
		if item.Count == 0 {
			continue
		}

		switch item.Tier {
		case models.BudgetTierIndie:
			labels = append(labels, "Indie")
		case models.BudgetTierMid:
			labels = append(labels, "Mid")
		case models.BudgetTierBlockbuster:
			labels = append(labels, "Blockbuster")
		default:
			labels = append(labels, "Unknown")
		}

		values = append(values, float64(item.Count))
	}

	return chart.Data{
		Labels: labels,
		Datasets: []chart.Dataset{{
			Label:           "Movies",
			Data:            values,
			BackgroundColor: colors,
		}},
	}
}

func formatRuntimeMinutes(minutes int64) string {
	if minutes <= 0 {
		return "N/A"
	}

	hours := minutes / 60
	remainingMinutes := minutes % 60

	if hours == 0 {
		return fmt.Sprintf("%d min", remainingMinutes)
	}

	if remainingMinutes == 0 {
		return fmt.Sprintf("%dh", hours)
	}

	return fmt.Sprintf("%dh %dm", hours, remainingMinutes)
}

func formatLargeNumber(value int64) string {
	if value >= 1_000_000_000 {
		return fmt.Sprintf("%.1fB", float64(value)/1_000_000_000)
	}
	if value >= 1_000_000 {
		return fmt.Sprintf("%.1fM", float64(value)/1_000_000)
	}
	if value >= 1_000 {
		return fmt.Sprintf("%.1fK", float64(value)/1_000)
	}
	return strconv.FormatInt(value, 10)
}

func formatROIPercent(roi float64) string {
	return fmt.Sprintf("%+.0f%%", roi*100)
}

templ StatsLoading() {
	<div id="stats-loading" class="htmx-indicator absolute inset-0 bg-background z-5 pointer-events-none overflow-hidden">
		<div class="p-4 space-y-8">
			// Header
			<div class="space-y-4">
				<div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3">
					<div class="space-y-2">
						@skeleton.Skeleton(skeleton.Props{Class: "h-12 w-48 rounded-lg"})
						@skeleton.Skeleton(skeleton.Props{Class: "h-4 w-64 rounded-lg"})
					</div>
					@skeleton.Skeleton(skeleton.Props{Class: "h-9 w-36 rounded-lg"})
				</div>
			</div>
			// At a glance
			@skeleton.Skeleton(skeleton.Props{Class: "h-6 w-36 rounded-lg"})
			@skeleton.Skeleton(skeleton.Props{Class: "h-40 w-full rounded-lg"})
			// Main sections
			for _ = range 5 {
				@skeleton.Skeleton(skeleton.Props{Class: "h-6 w-44 rounded-lg"})
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
					@skeleton.Skeleton(skeleton.Props{Class: "h-64 w-full rounded-lg"})
					@skeleton.Skeleton(skeleton.Props{Class: "h-64 w-full rounded-lg"})
				</div>
			}
		</div>
	</div>
}
