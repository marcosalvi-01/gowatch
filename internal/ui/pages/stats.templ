templ statsHeader(limit int) {
	<div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
		<div class="space-y-2">
			<h1 class="text-2xl sm:text-3xl font-bold">Statistics</h1>
			<p class="text-muted-foreground text-sm sm:text-base max-w-2xl">
				Overview of your movie watching habits and preferences.
			</p>
		</div>
		<form
			class="w-full sm:w-auto"
			hx-get="/stats"
			hx-target="#main-content"
			hx-trigger="change"
			hx-push-url="true"
			hx-swap="innerHTML scroll:#main-scroll-container:top"
			hx-indicator="#stats-loading"
		>
			@selectbox.SelectBox(selectbox.Props{Class: "w-full sm:w-36"}) {
				@selectbox.Trigger(selectbox.TriggerProps{Name: "limit", Class: "sm:w-36"}) {
					@selectbox.Value(selectbox.ValueProps{Placeholder: "Show"})
				}
				@selectbox.Content(selectbox.ContentProps{NoSearch: true}) {
					@selectbox.Item(selectbox.ItemProps{Value: "5", Selected: limit == 5}) {
						Show 5
					}
					@selectbox.Item(selectbox.ItemProps{Value: "10", Selected: limit == 10}) {
						Show 10
					}
					@selectbox.Item(selectbox.ItemProps{Value: "15", Selected: limit == 15}) {
						Show 15
					}
					@selectbox.Item(selectbox.ItemProps{Value: "20", Selected: limit == 20}) {
						Show 20
					}
				}
			}
		</form>
	</div>
}

